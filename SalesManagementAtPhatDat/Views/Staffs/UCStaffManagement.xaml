<UserControl x:Class="SalesManagementAtPhatDat.Views.Staffs.UCStaffManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagementAtPhatDat.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Staffs List"
                   Style="{DynamicResource TitleStaffListStyle}"/>
        <StackPanel Orientation="Horizontal" Grid.Column="1" Grid.Row="0"
                    
                    HorizontalAlignment="Right">
        <Button x:Name="btnAddStaff"
                
                Content="Add Staff" Click="btnAddStaff_Click"
                Style="{DynamicResource ButtonAddStaffStyle}"/>
        <Button x:Name="btnDeleteStaff"
                Content="Delete Staff"
                Style="{DynamicResource ButtonDeleteStaffStyle}" Click="btnDeleteStaff_Click"/>
        </StackPanel>
        <TextBox x:Name="txtSearchPhoneNumber"
                 Grid.Row="1" Grid.ColumnSpan="2"
                 Style="{DynamicResource TextBoxSearchStyle}"
                 TextChanged="txtSearchPhoneNumber_TextChanged"/>
        <TextBlock FontFamily="Segoe MDL2 Assets"
               Text="&#xE721;"
               FontSize="16"
               Foreground="Gray"
               Grid.Row="1" Grid.Column="0"
               Margin="25,32,0,0"
               IsHitTestVisible="False"
                   />
        <TextBlock
               Text="Search by Phone Number"
               FontSize="16"
               Foreground="Gray"
               Grid.Row="1" Grid.Column="0"
               Margin="50,28,0,0"
               IsHitTestVisible="False"
               x:Name="txtPlaceHolderSearch"
                Grid.ColumnSpan="2"/>
        <DataGrid AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Grid.Row="2" Grid.ColumnSpan="2"
                  x:Name="dgvStaffList"
                  Margin="5"
                  Style="{StaticResource DataGridListStaffStyle}"
                  MouseDoubleClick="dgvStaffList_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Staff's ID"
                                    Binding="{Binding StaffID}"
                                    Width="100"
                                    />
                <DataGridTextColumn Header="Full Name"
                                    Binding="{Binding FullName}"
                                    Width="150"/>
                <DataGridTextColumn Header="Phone Number"
                                    Binding="{Binding PhoneNumber}"
                                    Width="150"/>
                <DataGridTemplateColumn Header="Email" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">

                                <TextBlock Text="{Binding Email}"
                                    TextWrapping="NoWrap"/>
                            </ScrollViewer>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                
                <DataGridTemplateColumn Header="Address" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">

                                <TextBlock Text="{Binding Address}"
                           TextWrapping="NoWrap"/>

                            </ScrollViewer>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Role"
                                    Binding="{Binding Role}"
                                    Width="100"/>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
