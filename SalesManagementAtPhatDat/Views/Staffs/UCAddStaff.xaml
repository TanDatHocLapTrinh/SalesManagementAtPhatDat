<UserControl x:Class="SalesManagementAtPhatDat.Views.Staffs.UCAddStaff"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SalesManagementAtPhatDat.Views.Staffs"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button x:Name="btnReturn" Grid.Column="0" Grid.Row="0" 
                Click="btnReturn_Click"
                Height="30"
                Background="Transparent"
                BorderThickness="0"
                     >
            <Path Data="M 10 0 L 0 10 L 10 20"
                     Stroke="Black"
                        StrokeThickness="3"
                  />
        </Button>
        <TextBlock Text="ADD STAFF" Grid.Column="1" Grid.Row="0"
                           FontSize="28"
                           FontWeight="DemiBold"
                           FontFamily="Montserrat"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>


            <StackPanel Grid.ColumnSpan="2" Grid.Row="1">
                <TextBlock Text="Full name:"
                           Style="{StaticResource FontLabelInfomationStyle}"/>
                <TextBox x:Name="txtFullName"
                         Style="{StaticResource TextBoxAddStaffStyle}"/>

                <TextBlock Text="Phone Number:"
                           Style="{StaticResource FontLabelInfomationStyle}"/>
                <TextBox x:Name="txtPhoneNumber"
                         Style="{StaticResource TextBoxAddStaffStyle}"/>

                <TextBlock Text="Email:"
                           Style="{StaticResource FontLabelInfomationStyle}"/>
                <TextBox x:Name="txtEmail"
                         Style="{StaticResource TextBoxAddStaffStyle}"/>

                <TextBlock Text="Address:"
                           Style="{StaticResource FontLabelInfomationStyle}"/>
                <TextBox x:Name="txtAddress"
                         Style="{StaticResource TextBoxAddStaffStyle}"/>

                <TextBlock Text="Role:"
                           Style="{StaticResource FontLabelInfomationStyle}"/>
                <TextBox x:Name="txtRole"
                         Style="{StaticResource TextBoxAddStaffStyle}"/>
                <Button x:Name="btnSaveInforStaff"
                        Style="{StaticResource ButtonSaveStyle}"
                        Content="Save" Click="btnSaveInforStaff_Click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
