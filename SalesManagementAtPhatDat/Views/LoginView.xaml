<Window x:Class="SalesManagementAtPhatDat.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SalesManagementAtPhatDat.Views"
        mc:Ignorable="d"
        Title="Login" Height="270" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="5"
          >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="QUÁN CƠM PHÁT ĐẠT" Grid.ColumnSpan="2" Grid.Row="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{DynamicResource LoginFont}"
                   FontSize="30"
                   Foreground="#33CCFF"
                   FontWeight="DemiBold"/>
        
        <TextBlock Grid.Column="0" Grid.Row="1"
                   Text="👤Username:"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{DynamicResource LoginFont}"
                   />
        
        <TextBox Grid.Column="1" Grid.Row="1"
                 x:Name="txtUserName"
                 Style="{StaticResource LoginTextBox}"
                 />
        
        <TextBlock Grid.Column="0" Grid.Row="2"
                   Text="🔒 Password:"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{DynamicResource LoginFont}"/>
        
        <PasswordBox Grid.Column="1" Grid.Row="2"
                 x:Name="pwbPassword"
                 Style="{StaticResource LoginPasswordBox}"
                 />
        
        <WrapPanel Grid.ColumnSpan="2" Grid.Row="3"
                   HorizontalAlignment="Center">
            <Button Content="Login"
                    Margin="15"
                    x:Name="btnLogin"
                    Style="{StaticResource LoginButton}" 
                    Click="btnLogin_Click"
                    IsDefault="True"/>
        </WrapPanel>
        <TextBlock Grid.ColumnSpan="2" Grid.Row="4"
             Text="©Copyright 2026 DatDesign"
             FontFamily="Times New Roman"
             Foreground="LightGray"
             FontSize="14"
             VerticalAlignment="Bottom"
             HorizontalAlignment="Left"/>
        <TextBlock Grid.Column="1" Grid.Row="4"
             Text="Since 2016"
             FontFamily="Times New Roman"
             Foreground="LightGray"
             FontSize="14"
             VerticalAlignment="Bottom"
             HorizontalAlignment="Right"/>
    </Grid>
</Window>
